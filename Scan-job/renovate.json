{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 7am on monday"],
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": false
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "automerge": false
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "automerge": false
    }
  ]
}
